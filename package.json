{
  "name": "withfave",
  "version": "1.0.0",
  "description": "System pet app that displays CPU usage as character emotions",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package": "electron-builder --mac --win"
  },
  "keywords": [
    "electron",
    "system-monitor",
    "cpu",
    "tray-app",
    "pet"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "systeminformation": "^5.21.0"
  },
  "build": {
    "appId": "com.withfave.app",
    "productName": "withFave",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "system/**/*",
      "renderer/**/*",
      "assets/**/*"
    ]
  }
}