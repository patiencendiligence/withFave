{
  "name": "withfave",
  "version": "1.0.0",
  "description": "System pet app that displays CPU usage as character emotions",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:win:portable": "electron-builder --win portable",
    "package": "electron-builder --mac --win",
    "release": "electron-builder --mac --win -p always"
  },
  "keywords": [
    "electron",
    "system-monitor",
    "cpu",
    "tray-app",
    "pet"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "systeminformation": "^5.21.0"
  },
  "build": {
    "appId": "com.withfave.app",
    "productName": "withFave",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "system/**/*",
      "renderer/**/*",
      "assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "patiencendiligence",
      "repo": "withFave"
    }
  }
}